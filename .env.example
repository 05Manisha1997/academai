# academAI orchestration (optional — defaults to simulated, no keys required)

# Recommended after install: local Llama 2 via Ollama
ORCHESTRATOR_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Python sidecars: npm run orchestrators
LANGGRAPH_ORCHESTRATOR_URL=http://localhost:8001/orchestrate
AUTOGEN_ORCHESTRATOR_URL=http://localhost:8002/orchestrate

# ORCHESTRATOR_API_KEY=
